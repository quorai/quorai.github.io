---
---
<header class="topbar">
  <div class="brand">
    <img src="/assets/quorai_owl.png" class="brand-owl" alt="quorai owl" width="550" height="577" />
    <b>quorai</b>
    <span class="brand-meta">/ multi-agent trading sandbox</span>
  </div>

  <button class="burger" aria-label="Toggle menu" aria-expanded="false" aria-controls="topbar-nav">
    <span></span><span></span><span></span>
  </button>

  <nav id="topbar-nav">
    <a href="#about">About</a>
    <a href="#compare">Compare</a>
    <a href="#pipeline">Pipeline</a>
    <a href="#agents">Agents</a>
    <a href="#math">Method</a>
    <a href="#measure">Measurement</a>
    <a href="#safety">Safety</a>
    <a href="#run">Run</a>
    <a href="#inspector">UI</a>
    <a class="gh" href="https://github.com/quorai/quorai" target="_blank" rel="noopener">
      <svg width="13" height="13" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
        <path d="M8 0C3.58 0 0 3.58 0 8a8 8 0 005.47 7.59c.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82a7.42 7.42 0 014 0c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0016 8c0-4.42-3.58-8-8-8z"/>
      </svg>
      github
    </a>
  </nav>
</header>

<script>
  const burger = document.querySelector('.burger') as HTMLButtonElement;
  const nav    = document.getElementById('topbar-nav') as HTMLElement;

  burger.addEventListener('click', () => {
    const open = burger.getAttribute('aria-expanded') === 'true';
    burger.setAttribute('aria-expanded', String(!open));
    nav.classList.toggle('open', !open);
  });

  nav.querySelectorAll('a').forEach(a => {
    a.addEventListener('click', () => {
      burger.setAttribute('aria-expanded', 'false');
      nav.classList.remove('open');
    });
  });
</script>
